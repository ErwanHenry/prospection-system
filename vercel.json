{
  "version": 2,
  "buildCommand": "echo 'No build needed - static files + serverless'",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/production-server.js"
    },
    {
      "source": "/",
      "destination": "/frontend/campaign-dashboard.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
